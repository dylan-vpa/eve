# Configuración SIP

SIP_HOST=sip.example.com

#

SIP_USERNAME=tu_usuario

#

SIP_PASSWORD=tu_contraseña

# API Keys

DEEPGRAM_API_KEY=tu_clave_deepgram

#

ELEVENLABS_API_KEY=tu_clave_elevenlabs

#

ELEVENLABS_VOICE_ID=tu_voz_id

# Configuración de audio (opcional)

SAMPLE_RATE=16000

#

CHUNK_DURATION=2.0

# Configuración de IA (opcional)

AI_MODEL_TYPE=ollama

AI_MODEL_NAME=llama2

OLLAMA_URL=http://localhost:11434

AI_MAX_LENGTH=200

AI_TEMPERATURE=0.7

AI_USE_GPU=False

AI_DEVICE=cpu 